# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
functions/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# firebase functions (compiled)
/functions/lib

# local only — MailerLite API token for `firebase functions:secrets:set --data-file`
/functions/.mailerlite-api-token
/functions/.mailerlite-webhook-secret

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
